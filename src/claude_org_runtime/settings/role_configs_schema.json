              },
              {
                "type": "command",
                "command": "bash \"{claude_org_path}/.hooks/block-dangerous-git.sh\""
              },
              {
                "type": "command",
                "command": "bash \"{claude_org_path}/.hooks/block-no-verify.sh\""
              },
              {
                "type": "command",
                "command": "bash \"{claude_org_path}/.hooks/block-org-structure.sh\""
